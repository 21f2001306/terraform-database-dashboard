app_name   = "whatson-multiaccount"
aws_region = "eu-west-2"

# Roles to assume — get these from each prod account's
# 'cross-account-role' deployment output.
cross_account_role_arns = [
  "arn:aws:iam::111111111111:role/whatson-dashboard-readonly",
  "arn:aws:iam::222222222222:role/whatson-dashboard-readonly",
]

# After first deployment, tighten CORS:
# allowed_cors_origins = ["https://abc123.cloudfront.net"]